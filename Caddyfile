{
	auto_https off
	admin off
	persist_config off
}

:{$PORT:3000} {
	log {
		output stdout
		format console
		level INFO
	}

	# IMPORTANT — directive ordering in Caddy:
	# `basic_auth` and `reverse_proxy` at the site-block top level run in
	# Caddy's CANONICAL order regardless of declaration order. basic_auth
	# always runs before any handle block. To carve out an exemption, the
	# basic_auth must live INSIDE a `handle` block — the matcher then gates
	# whether basic_auth runs at all for that request.
	#
	# Multiple handle blocks are evaluated in declaration order; first match
	# wins, subsequent handles are skipped.

	# Passthrough paths — never gated by basic_auth.
	#
	# Why: Browsers auto-attach cached HTTP Basic Auth ONLY on full page
	# navigations. Fetch/XHR calls in CORS mode (which the dashboard SPA
	# uses for every /api/* call — Sec-Fetch-Mode: cors visible in access
	# logs) do NOT carry cached basic_auth credentials, even on same-origin
	# requests. If Caddy returns 401 + WWW-Authenticate on those fetches,
	# the browser interprets as fresh challenge and re-prompts. Infinite
	# loop after first login. Also relevant: <script crossorigin> and
	# <link crossorigin> tags in the dashboard's index.html.
	#
	# These paths contain no secrets — compiled JS/CSS, icons, fonts, the
	# REST API surface. The dashboard's own ephemeral session token
	# (X-Hermes-Session-Token, regenerated per dashboard restart, injected
	# into the SPA HTML) is the real auth on /api/* — and its 401 does NOT
	# include WWW-Authenticate, so it doesn't trigger browser prompts.
	#
	# Security model: basic_auth gates the perimeter (initial / load and
	# SPA route loads — full page navigations). Session token gates /api/*
	# at the application layer. Attacker can probe /api/* without basic_auth
	# but can't get a valid session token without first loading / which IS
	# gated.
	@passthrough path /api/* /assets/* /dashboard-plugins/* /favicon.ico /favicon.svg /robots.txt /manifest.json /apple-touch-icon.png

	handle @passthrough {
		reverse_proxy 127.0.0.1:9119 {
			header_up Host 127.0.0.1
		}
	}

	# Default catch-all — gates the SPA navigation routes (/, /sessions,
	# /config, /skills, /plugins, /files, /cron, /logs, /analytics, etc.)
	# Browser auto-attaches basic_auth on these because they're full page
	# navigations.
	#
	# Username: hermes
	# Password: $HERMES_PASSWORD (bcrypt hash computed at entrypoint startup)
	handle {
		basic_auth {
			hermes {$HERMES_PASSWORD_HASH}
		}
		# Reverse proxy to native Hermes dashboard on loopback. Host
		# header rewrite satisfies the dashboard's DNS-rebinding protection
		# (Host allowlist in loopback bind mode).
		reverse_proxy 127.0.0.1:9119 {
			header_up Host 127.0.0.1
		}
	}
}
