{
	auto_https off
	admin off
	persist_config off
}

:{$PORT:3000} {
	log {
		output stdout
		format console
		level INFO
	}

	# Bypass basic_auth for paths the SPA fetches programmatically.
	#
	# Why: HTTP Basic Auth is auto-attached by browsers ONLY on full page
	# navigations. For fetch() / XHR calls in CORS mode (which is what the
	# dashboard SPA uses for every /api/* call — see Sec-Fetch-Mode: cors
	# in access logs), the cached basic_auth credentials are NOT attached.
	# The fetch hits Caddy with no auth → Caddy returns 401 + WWW-Authenticate
	# → browser interprets as fresh auth challenge → re-prompts user even
	# though they already logged in.
	#
	# Symptom (2026-04-25): infinite "Sign in" loop on https://hermes.uncannylabs.ai
	# after first login. Every /api/sessions, /api/status, etc. fetch
	# triggered another prompt.
	#
	# Fix: bypass basic_auth for the API + static surface. Dashboard's own
	# ephemeral session token (X-Hermes-Session-Token, regenerated per
	# dashboard restart, injected into the SPA HTML) is the real auth on
	# /api/* — and its 401 does NOT include WWW-Authenticate, so it
	# doesn't trigger browser prompts.
	#
	# Security model: basic_auth gates the perimeter (initial page load
	# of /, /sessions, /config, etc — full page navigations). The session
	# token gates /api/* (defense in depth). An attacker can hit /api/*
	# without basic_auth but can't get a valid session token without
	# loading / first, which IS gated.
	@passthrough path /api/* /assets/* /dashboard-plugins/* /favicon.ico /favicon.svg /robots.txt /manifest.json /apple-touch-icon.png
	handle @passthrough {
		reverse_proxy 127.0.0.1:9119 {
			header_up Host 127.0.0.1
		}
	}

	# All other paths (/, /sessions, /config, /skills, /plugins, /files,
	# /cron, /logs, /analytics, /system, etc. — i.e., SPA navigation routes
	# that load the index.html shell) require Basic Auth.
	# Username: hermes
	# Password: $HERMES_PASSWORD (bcrypt hash computed at entrypoint startup)
	basic_auth {
		hermes {$HERMES_PASSWORD_HASH}
	}

	# Reverse proxy to the native Hermes dashboard on loopback.
	# Host header rewrite satisfies the dashboard's DNS-rebinding protection
	# (it accepts only loopback hostnames when bound to 127.0.0.1).
	reverse_proxy 127.0.0.1:9119 {
		header_up Host 127.0.0.1
	}
}
