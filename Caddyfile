{
	auto_https off
	admin off
	persist_config off
}

:{$PORT:3000} {
	log {
		output stdout
		format console
		level INFO
	}

	# Gate the entire surface behind HTTP Basic Auth.
	# Username: hermes
	# Password: $HERMES_PASSWORD (bcrypt hash computed at entrypoint startup)
	basic_auth {
		hermes {$HERMES_PASSWORD_HASH}
	}

	# Viewer — browse /root/.hermes read-only with explicit secret blocklist.
	redir /viewer /viewer/ 302

	handle_path /viewer/* {
		root * /root/.hermes

		# Explicit 404 for secrets + internal-state files. path matchers here
		# are evaluated AFTER handle_path strips /viewer/, so patterns are
		# relative to /root/.hermes.
		@blocked path /auth.json /auth.lock /.env /.gitconfig /.skills_prompt_snapshot.json
		@blocked path /gateway.lock /gateway.pid /gateway_state.json
		@blocked path /channel_directory.json /models_dev_cache.json /context_length_cache.yaml
		@blocked path /response_store.db /response_store.db-shm /response_store.db-wal
		@blocked path /state.db /state.db-shm /state.db-wal
		@blocked path /lost+found/* /cache/* /sandboxes/*
		@blocked path *.lock *.pid
		respond @blocked "" 404

		# Force inline text rendering so browsers don't download yaml/md/json etc.
		@text path *.yaml *.yml *.md *.txt *.log *.py *.sh *.js *.ts *.css *.json *.toml *.ini *.conf *.cfg
		header @text Content-Type "text/plain; charset=utf-8"
		header @text Content-Disposition "inline"

		# Prevent Railway/Fastly from caching viewer responses — files change
		# on the volume and we don't want stale content served after edits.
		header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

		# Directory listings also hide blocked files (cosmetic; 404 above is
		# the real guard).
		file_server browse {
			hide auth.json auth.lock .env .gitconfig .skills_prompt_snapshot.json
			hide gateway.lock gateway.pid gateway_state.json
			hide channel_directory.json models_dev_cache.json context_length_cache.yaml
			hide response_store.db response_store.db-shm response_store.db-wal
			hide state.db state.db-shm state.db-wal
			hide lost+found cache sandboxes
		}
	}

	# Everything else — reverse proxy to native Hermes dashboard.
	# Rewrite Host header to 127.0.0.1 so the dashboard's DNS-rebinding
	# protection (Host allowlist in loopback bind mode) accepts the request.
	handle {
		reverse_proxy 127.0.0.1:9119 {
			header_up Host 127.0.0.1
		}
	}
}
